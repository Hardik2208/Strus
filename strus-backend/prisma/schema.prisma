generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

//
// ======================================================
// ENUMS
// ======================================================
//

enum UserStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

enum VerificationLevel {
  EMAIL
  PHONE
  KYC
}

enum OAuthProvider {
  GOOGLE
}

enum DevicePlatform {
  WEB
  WINDOWS
  MACOS
  LINUX
  IOS
  ANDROID
}

enum SessionStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

enum WorkspaceType {
  PERSONAL
  TEAM
}

enum WorkspaceRole {
  OWNER
  ADMIN
  MEMBER
}

enum WorkspaceInvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
}

enum AuditAction {
  WORKSPACE_CREATED
  WORKSPACE_UPDATED
  WORKSPACE_DELETED

  MEMBER_JOINED
  MEMBER_REMOVED

  MEMBER_PROMOTED
  MEMBER_DEMOTED

  INVITATION_CREATED
  INVITATION_ACCEPTED
  INVITATION_DECLINED
  INVITATION_CANCELLED

  OWNERSHIP_TRANSFERRED
}

enum ProjectStatus {
  DRAFT
  ACTIVE
  COMPLETED
  CANCELLED
  MUTUALLY_TERMINATED
}

enum ProjectAuditAction {
  CREATED
  UPDATED

  STATUS_CHANGED

  ACTIVATED
  COMPLETED

  CANCELLED
  MUTUALLY_TERMINATED

  DELETED
}

enum ProjectSetupStage {
  PROJECT_CREATED
  AGREEMENT_COMPLETED
  PROFESSIONALS_ASSIGNED
  MILESTONES_CREATED
  READY_TO_START
}

enum AgreementParticipantRole {
  CLIENT
  PROFESSIONAL
}

enum AgreementInvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
  WITHDRAWN
}

enum AgreementAuditAction {
  CREATED
  UPDATED

  PROFESSIONAL_INVITED
  INVITATION_ACCEPTED
  INVITATION_DECLINED
  INVITATION_WITHDRAWN

  PROFESSIONAL_REMOVED
}

enum MilestoneStatus {
  NOT_STARTED
  IN_PROGRESS
  SUBMITTED
  REVISION_REQUESTED
  REVISION_LIMIT_REACHED
  COMPLETED
}

enum ExecutionAuditAction {
  MILESTONE_CREATED
  MILESTONE_UPDATED
  MILESTONE_DELETED

  MILESTONE_STARTED
  MILESTONE_SUBMITTED
  MILESTONE_APPROVED
  MILESTONE_REJECTED

  DEPENDENCY_CREATED
  DEPENDENCY_REMOVED

  EXTENSION_GRANTED

  REVISION_REQUESTED
  REVISION_SUBMITTED
  REVISION_LIMIT_REACHED

  PROJECT_ASSET_CREATED
  PROJECT_ASSET_UPDATED
  PROJECT_ASSET_DELETED
}

enum SubmissionStatus {
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REVISION_REQUESTED
  REJECTED
}

enum SubmissionAttachmentType {
  DOCUMENT
  IMAGE
  VIDEO
  ARCHIVE
  OTHER
}

enum SubmissionTiming {
  ON_TIME
  LATE
}

//
// ======================================================
// AUTHENTICATION
// ======================================================
//

model User {
  id String @id @default(uuid()) @db.Uuid

  email String @unique @db.VarChar(320)

  passwordHash String? @map("password_hash") @db.VarChar(255)

  status UserStatus @default(ACTIVE)

  verificationLevel VerificationLevel @default(EMAIL) @map("verification_level")

  profileCompleted Boolean @default(false) @map("profile_completed")

  lastLoginAt DateTime? @map("last_login_at")

  passwordChangedAt DateTime? @map("password_changed_at")

  deletedAt DateTime? @map("deleted_at")

  createdAt DateTime @default(now()) @map("created_at")

  updatedAt DateTime @updatedAt @map("updated_at")

  //
  // Workspace Relations
  //

  ownedWorkspaces Workspace[] @relation("WorkspaceOwner")

  workspaceMemberships WorkspaceMember[]

  sentWorkspaceInvitations WorkspaceInvitation[] @relation("WorkspaceInvitationSender")

  receivedWorkspaceInvitations WorkspaceInvitation[] @relation("WorkspaceInvitationRecipient")

  auditLogs WorkspaceAuditLog[]

  //
  // Project Relations
  //

  agreementsCreated Agreement[] @relation("AgreementCreatedBy")

  agreementsUpdated Agreement[] @relation("AgreementUpdatedBy")

  agreementParticipants AgreementParticipant[]

  agreementAudits AgreementAudit[]

  //
  // Other Relations
  //

  profile UserProfile?

  oauthAccounts OAuthAccount[]

  devices Device[]

  sessions Session[]

  milestonesCreated Milestone[] @relation("MilestoneCreatedBy")

  milestonesUpdated Milestone[] @relation("MilestoneUpdatedBy")

  executionAudits ExecutionAudit[] @relation("ExecutionAuditActor")

  milestoneExtensions MilestoneExtension[] @relation("MilestoneExtensionApprovedBy")

  createdProjectAssets ProjectAsset[] @relation("ProjectAssetCreatedBy")

  clientReputation ClientReputation?

  professionalReputation ProfessionalReputation?
  projects               Project[]
  projectAudits          ProjectAudit[]

  submittedMilestoneSubmissions MilestoneSubmission[] @relation("MilestoneSubmissionSubmittedBy")

  reviewedMilestoneSubmissions MilestoneSubmission[] @relation("MilestoneSubmissionReviewedBy")

  revisionRequests RevisionRequest[] @relation("RevisionRequestedBy")

  @@index([status])
  @@index([verificationLevel])
  @@index([deletedAt])
  @@map("users")
}

//
// ======================================================
// USER PROFILE
// ======================================================
//

model UserProfile {
  id String @id @default(uuid()) @db.Uuid

  userId String @unique @map("user_id") @db.Uuid

  username String @unique @db.VarChar(30)

  firstName String @map("first_name") @db.VarChar(50)

  lastName String @map("last_name") @db.VarChar(50)

  bio String? @db.VarChar(500)

  avatarUrl String? @map("avatar_url") @db.VarChar(500)

  avatarPublicId String? @map("avatar_public_id") @db.VarChar(255)

  countryCode String @map("country_code") @db.Char(2)

  timezone String @db.VarChar(100)

  createdAt DateTime @default(now()) @map("created_at")

  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

//
// ======================================================
// REPUTATION (READ MODELS)
// ======================================================
//

model ClientReputation {
  userId String @id @db.Uuid

  score Decimal @default(0) @db.Decimal(5, 2)

  totalProjects Int @default(0) @map("total_projects")

  successfulProjects Int @default(0) @map("successful_projects")

  createdAt DateTime @default(now()) @map("created_at")

  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("client_reputations")
}

model ProfessionalReputation {
  userId String @id @db.Uuid

  score Decimal @default(0) @db.Decimal(5, 2)

  totalProjects Int @default(0) @map("total_projects")

  completedProjects Int @default(0) @map("completed_projects")

  createdAt DateTime @default(now()) @map("created_at")

  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("professional_reputations")
}

//
// ======================================================
// OAUTH
// ======================================================
//

model OAuthAccount {
  id String @id @default(uuid()) @db.Uuid

  userId String @map("user_id") @db.Uuid

  provider OAuthProvider

  providerUserId String @map("provider_user_id") @db.VarChar(255)

  providerEmail String @map("provider_email") @db.VarChar(320)

  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@map("oauth_accounts")
}

//
// ======================================================
// DEVICES
// ======================================================
//

model Device {
  id String @id @default(uuid()) @db.Uuid

  userId String @map("user_id") @db.Uuid

  deviceIdentifier String @map("device_identifier") @db.VarChar(255)

  deviceName String? @map("device_name") @db.VarChar(150)

  platform DevicePlatform

  browser String? @db.VarChar(100)

  operatingSystem String? @map("operating_system") @db.VarChar(100)

  lastSeenAt DateTime @map("last_seen_at")

  createdAt DateTime @default(now()) @map("created_at")

  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  sessions Session[]

  @@unique([userId, deviceIdentifier])
  @@index([userId])
  @@map("devices")
}

//
// ======================================================
// SESSIONS
// ======================================================
//

model Session {
  id String @id @default(uuid()) @db.Uuid

  userId String @map("user_id") @db.Uuid

  deviceId String @map("device_id") @db.Uuid

  refreshTokenHash String @unique @map("refresh_token_hash") @db.VarChar(255)

  status SessionStatus @default(ACTIVE)

  expiresAt DateTime @map("expires_at")

  lastActivityAt DateTime @map("last_activity_at")

  revokedAt DateTime? @map("revoked_at")

  createdAt DateTime @default(now()) @map("created_at")

  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  device Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([deviceId])
  @@index([expiresAt])
  @@index([userId, status, lastActivityAt(sort: Desc)])
  @@map("sessions")
}

//
// ======================================================
// Workspace
// ======================================================
//

model Workspace {
  id String @id @default(uuid()) @db.Uuid

  ownerId String @map("owner_id") @db.Uuid

  owner User @relation("WorkspaceOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  name String @db.VarChar(100)

  slug String @unique @db.VarChar(120)

  description String? @db.VarChar(1000)

  workspaceType WorkspaceType @map("workspace_type")

  members WorkspaceMember[]

  invitations WorkspaceInvitation[]

  createdAt DateTime @default(now()) @map("created_at")

  updatedAt DateTime @updatedAt @map("updated_at")

  auditLogs WorkspaceAuditLog[]
  projects  Project[]

  @@index([ownerId])
  @@map("workspaces")
}

model WorkspaceMember {
  workspaceId String @map("workspace_id") @db.Uuid
  userId      String @map("user_id") @db.Uuid

  role WorkspaceRole

  joinedAt DateTime @default(now()) @map("joined_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([workspaceId, userId])
  @@index([userId])
  @@index([workspaceId])
  @@map("workspace_members")
}

model WorkspaceInvitation {
  id String @id @default(uuid()) @db.Uuid

  workspaceId String    @map("workspace_id") @db.Uuid
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  invitedByUserId String @map("invited_by_user_id") @db.Uuid
  invitedBy       User   @relation("WorkspaceInvitationSender", fields: [invitedByUserId], references: [id], onDelete: Cascade)

  invitedUserId String @map("invited_user_id") @db.Uuid

  invitedUser User @relation("WorkspaceInvitationRecipient", fields: [invitedUserId], references: [id], onDelete: Cascade)

  status WorkspaceInvitationStatus @default(PENDING)

  expiresAt DateTime @map("expires_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([workspaceId])
  @@index([invitedUserId])
  @@index([status])
  @@map("workspace_invitations")
}

model WorkspaceAuditLog {
  id String @id @default(uuid()) @db.Uuid

  workspaceId String    @map("workspace_id") @db.Uuid
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  actorId String @map("actor_id") @db.Uuid
  actor   User   @relation(fields: [actorId], references: [id], onDelete: Cascade)

  action AuditAction

  entityId String? @map("entity_id") @db.Uuid

  metadata Json?

  createdAt DateTime @default(now()) @map("created_at")

  @@index([workspaceId, createdAt(sort: Desc)])
  @@index([actorId])
  @@map("workspace_audit_logs")
}

//
// ======================================================
// Project
// ======================================================
//

model Project {
  id String @id @default(uuid()) @db.Uuid

  workspaceId String @db.Uuid
  createdById String @db.Uuid

  title       String  @db.VarChar(150)
  description String? @db.VarChar(5000)

  status ProjectStatus @default(DRAFT)

  setupStage ProjectSetupStage @default(PROJECT_CREATED) @map("setup_stage")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  createdBy User      @relation(fields: [createdById], references: [id], onDelete: Restrict)

  audits    ProjectAudit[]
  agreement Agreement?

  milestones               Milestone[]
  executionAudits          ExecutionAudit[]
  projectAssets            ProjectAsset[]
  projectAssetVisibilities ProjectAssetVisibility[]

  @@index([workspaceId])
  @@index([createdById])
  @@index([status])
  @@index([deletedAt])
  @@index([workspaceId, status])
  @@index([workspaceId, createdAt(sort: Desc)])
  @@map("projects")
}

model ProjectAudit {
  id String @id @default(uuid()) @db.Uuid

  projectId String  @db.Uuid
  actorId   String? @db.Uuid

  action ProjectAuditAction

  metadata Json?

  ipAddress String? @db.VarChar(45)
  userAgent String? @db.VarChar(512)

  createdAt DateTime @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  actor   User?   @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([actorId])
  @@index([action])
  @@index([createdAt])
  @@map("project_audits")
}

//
// ======================================================
// Agreement
// ======================================================
//

model Agreement {
  id               String                 @id @default(uuid()) @db.Uuid
  projectId        String                 @unique @db.Uuid
  title            String                 @db.VarChar(150)
  description      String?                @db.VarChar(5000)
  scope            String?                @db.Text
  outOfScope       String?                @db.Text
  budget           Decimal                @db.Decimal(15, 2)
  expectedDuration Int                    @map("expected_duration")
  createdById      String                 @db.Uuid
  lastUpdatedById  String                 @db.Uuid
  createdAt        DateTime               @default(now()) @map("created_at")
  updatedAt        DateTime               @updatedAt @map("updated_at")
  project          Project                @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy        User                   @relation("AgreementCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  lastUpdatedBy    User                   @relation("AgreementUpdatedBy", fields: [lastUpdatedById], references: [id], onDelete: Restrict)
  participants     AgreementParticipant[]
  audits           AgreementAudit[]

  @@index([createdById])
  @@map("agreements")
}

model AgreementParticipant {
  id               String                    @id @default(uuid()) @db.Uuid
  agreementId      String                    @db.Uuid
  userId           String                    @db.Uuid
  role             AgreementParticipantRole
  invitationStatus AgreementInvitationStatus @default(PENDING) @map("invitation_status")
  invitedAt        DateTime                  @default(now()) @map("invited_at")
  respondedAt      DateTime?                 @map("responded_at")
  joinedAt         DateTime?                 @map("joined_at")
  createdAt        DateTime                  @default(now()) @map("created_at")
  updatedAt        DateTime                  @updatedAt @map("updated_at")
  agreement        Agreement                 @relation(fields: [agreementId], references: [id], onDelete: Cascade)
  user             User                      @relation(fields: [userId], references: [id], onDelete: Cascade)

  milestones           Milestone[]
  visibleProjectAssets ProjectAssetVisibility[]

  @@index([agreementId, createdAt(sort: Desc)])
  @@index([agreementId, userId, respondedAt])
  @@index([userId])
  @@index([agreementId, invitationStatus])
  @@index([agreementId, role])
  @@index([userId, invitationStatus])
  @@map("agreement_participants")
}

model AgreementAudit {
  id          String               @id @default(uuid()) @db.Uuid
  agreementId String               @db.Uuid
  actorId     String?              @db.Uuid
  action      AgreementAuditAction
  metadata    Json?
  ipAddress   String?              @db.VarChar(45)
  userAgent   String?              @db.VarChar(512)
  createdAt   DateTime             @default(now()) @map("created_at")
  agreement   Agreement            @relation(fields: [agreementId], references: [id], onDelete: Cascade)
  actor       User?                @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([agreementId, createdAt(sort: Desc)])
  @@index([actorId])
  @@index([action])
  @@map("agreement_audits")
}

//
// ======================================================
// Execution
// ======================================================
//

model Milestone {
  id String @id @default(uuid()) @db.Uuid

  projectId String @map("project_id") @db.Uuid

  agreementParticipantId String @map("agreement_participant_id") @db.Uuid

  order Int

  allocatedDays Int @map("allocated_days")

  extensionDays Int @default(0) @map("extension_days")

  paymentAllocation Decimal @map("payment_allocation") @db.Decimal(18, 2)

  revisionLimit Int @default(0) @map("revision_limit")

  revisionCount Int @default(0) @map("revision_count")

  status MilestoneStatus @default(NOT_STARTED)

  startedAt DateTime? @map("started_at")

  submittedAt DateTime? @map("submitted_at")

  completedAt DateTime? @map("completed_at")

  createdById String @map("created_by_id") @db.Uuid

  updatedById String @map("updated_by_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at")

  updatedAt DateTime @updatedAt @map("updated_at")

  deletedAt DateTime? @map("deleted_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  agreementParticipant AgreementParticipant @relation(fields: [agreementParticipantId], references: [id], onDelete: Restrict)

  createdBy User @relation("MilestoneCreatedBy", fields: [createdById], references: [id])

  updatedBy User @relation("MilestoneUpdatedBy", fields: [updatedById], references: [id])

  acceptanceCriteria MilestoneAcceptanceCriteria[]

  deliverables MilestoneDeliverable[]

  extensions       MilestoneExtension[]
  executionAudits  ExecutionAudit[]
  requirements     MilestoneRequirement[]
  submissions      MilestoneSubmission[]
  revisionRequests RevisionRequest[]

  @@unique([agreementParticipantId, order])
  @@index([projectId])
  @@index([agreementParticipantId])
  @@index([status])
  @@index([deletedAt])
  @@map("milestones")
}

model MilestoneExtension {
  id String @id @default(uuid()) @db.Uuid

  milestoneId String @map("milestone_id") @db.Uuid

  daysAdded Int @map("days_added")

  reason String? @db.Text

  approvedById String @map("approved_by_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at")

  milestone Milestone @relation(fields: [milestoneId], references: [id], onDelete: Cascade)

  approvedBy User @relation("MilestoneExtensionApprovedBy", fields: [approvedById], references: [id])

  @@index([milestoneId])
  @@map("milestone_extensions")
}

model ExecutionAudit {
  id String @id @default(uuid()) @db.Uuid

  projectId String @map("project_id") @db.Uuid

  actorId String? @map("actor_id") @db.Uuid

  milestoneId String? @map("milestone_id") @db.Uuid

  action ExecutionAuditAction

  metadata Json?

  ipAddress String? @map("ip_address") @db.VarChar(45)

  userAgent String? @map("user_agent") @db.VarChar(512)

  createdAt DateTime @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  actor User? @relation("ExecutionAuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  milestone Milestone? @relation(fields: [milestoneId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([milestoneId])
  @@index([actorId])
  @@index([action])
  @@index([createdAt])
  @@map("execution_audits")
}

model MilestoneRequirement {
  id String @id @default(uuid()) @db.Uuid

  milestoneId String @map("milestone_id") @db.Uuid

  content String @db.Text

  order Int

  createdAt DateTime @default(now()) @map("created_at")

  updatedAt DateTime @updatedAt @map("updated_at")

  milestone Milestone @relation(fields: [milestoneId], references: [id], onDelete: Cascade)

  @@unique([milestoneId, order])
  @@index([milestoneId])
  @@map("milestone_requirements")
}

model MilestoneDeliverable {
  id String @id @default(uuid()) @db.Uuid

  milestoneId String @map("milestone_id") @db.Uuid

  content String @db.Text

  order Int

  isMandatory Boolean @default(true) @map("is_mandatory")

  createdAt DateTime @default(now()) @map("created_at")

  updatedAt DateTime @updatedAt @map("updated_at")

  milestone Milestone @relation(fields: [milestoneId], references: [id], onDelete: Cascade)

  @@unique([milestoneId, order])
  @@index([milestoneId])
  @@map("milestone_deliverables")
}

model MilestoneAcceptanceCriteria {
  id String @id @default(uuid()) @db.Uuid

  milestoneId String @map("milestone_id") @db.Uuid

  content String @db.Text

  order Int

  createdAt DateTime @default(now()) @map("created_at")

  updatedAt DateTime @updatedAt @map("updated_at")

  milestone Milestone @relation(fields: [milestoneId], references: [id], onDelete: Cascade)

  @@unique([milestoneId, order])
  @@index([milestoneId])
  @@map("milestone_acceptance_criteria")
}

model ProjectAsset {
  id String @id @default(uuid()) @db.Uuid

  projectId String @map("project_id") @db.Uuid

  createdById String @map("created_by_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at")

  updatedAt DateTime @updatedAt @map("updated_at")

  deletedAt DateTime? @map("deleted_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdBy User @relation("ProjectAssetCreatedBy", fields: [createdById], references: [id])

  files ProjectAssetFile[]

  visibleToParticipants ProjectAssetVisibility[]

  @@index([projectId])
  @@index([deletedAt])
  @@map("project_assets")
}

model ProjectAssetFile {
  id String @id @default(uuid()) @db.Uuid

  projectAssetId String @map("project_asset_id") @db.Uuid

  publicId String @map("public_id") @db.VarChar(255)

  url String @db.Text

  originalName String @map("original_name") @db.VarChar(255)

  mimeType String @map("mime_type") @db.VarChar(100)

  extension String @db.VarChar(20)

  size BigInt

  uploadedAt DateTime @default(now()) @map("uploaded_at")

  asset ProjectAsset @relation(fields: [projectAssetId], references: [id], onDelete: Cascade)

  @@index([projectAssetId])
  @@map("project_asset_files")
}

model ProjectAssetVisibility {
  id String @id @default(uuid()) @db.Uuid

  projectId String @map("project_id") @db.Uuid

  projectAssetId String @map("project_asset_id") @db.Uuid

  agreementParticipantId String @map("agreement_participant_id") @db.Uuid

  asset ProjectAsset @relation(fields: [projectAssetId], references: [id], onDelete: Cascade)

  participant AgreementParticipant @relation(fields: [agreementParticipantId], references: [id], onDelete: Cascade)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectAssetId, agreementParticipantId])
  @@index([projectId])
  @@index([agreementParticipantId])
  @@map("project_asset_visibility")
}

model MilestoneSubmission {
  id String @id @default(uuid()) @db.Uuid

  milestoneId String @map("milestone_id") @db.Uuid

  submittedById String @map("submitted_by_id") @db.Uuid

  submissionNumber Int @map("submission_number")

  content String? @db.Text

  status SubmissionStatus @default(SUBMITTED)

  timing SubmissionTiming @default(ON_TIME)

  reviewedById String? @map("reviewed_by_id") @db.Uuid

  submittedAt DateTime @default(now()) @map("submitted_at")

  reviewedAt DateTime? @map("reviewed_at")

  createdAt DateTime @default(now()) @map("created_at")

  updatedAt DateTime @updatedAt @map("updated_at")

  deletedAt DateTime? @map("deleted_at")

  milestone Milestone @relation(fields: [milestoneId], references: [id], onDelete: Cascade)

  submittedBy User @relation("MilestoneSubmissionSubmittedBy", fields: [submittedById], references: [id], onDelete: Restrict)

  reviewedBy User? @relation("MilestoneSubmissionReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)

  attachments     SubmissionAttachment[]
  revisionRequest RevisionRequest?

  @@unique([milestoneId, submissionNumber])
  @@index([reviewedById])
  @@index([milestoneId])
  @@index([submittedById])
  @@index([status])
  @@index([deletedAt])
  @@map("milestone_submissions")
}

model SubmissionAttachment {
  id String @id @default(uuid()) @db.Uuid

  submissionId String @map("submission_id") @db.Uuid

  publicId String @map("public_id") @db.VarChar(255)

  url String @db.Text

  originalName String @map("original_name") @db.VarChar(255)

  mimeType String @map("mime_type") @db.VarChar(100)

  extension String @db.VarChar(20)

  attachmentType SubmissionAttachmentType @map("attachment_type")

  size BigInt

  uploadedAt DateTime @default(now()) @map("uploaded_at")

  submission MilestoneSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId])
  @@index([attachmentType])
  @@map("submission_attachments")
}

model RevisionRequest {
  id String @id @default(cuid())

  milestoneId String    @db.Uuid
  milestone   Milestone @relation(fields: [milestoneId], references: [id], onDelete: Cascade)

  submissionId String              @db.Uuid
  submission   MilestoneSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  requestedById String @db.Uuid
  requestedBy   User   @relation("RevisionRequestedBy", fields: [requestedById], references: [id])

  revisionNumber Int

  content String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([submissionId])
  @@index([milestoneId, revisionNumber])
  @@index([milestoneId])
  @@index([requestedById])
}