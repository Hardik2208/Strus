generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

//
// ======================================================
// ENUMS
// ======================================================
//

enum UserStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

enum VerificationLevel {
  EMAIL
  PHONE
  KYC
}

enum OAuthProvider {
  GOOGLE
}

enum DevicePlatform {
  WEB
  WINDOWS
  MACOS
  LINUX
  IOS
  ANDROID
}

enum SessionStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

//
// ======================================================
// AUTHENTICATION
// ======================================================
//

model User {
  id String @id @default(uuid()) @db.Uuid

  email String @unique @db.VarChar(320)

  passwordHash String? @map("password_hash") @db.VarChar(255)

  status UserStatus @default(ACTIVE)

  verificationLevel VerificationLevel @default(EMAIL) @map("verification_level")

  lastLoginAt DateTime? @map("last_login_at")

  createdAt DateTime @default(now()) @map("created_at")

  updatedAt DateTime @updatedAt @map("updated_at")

  passwordChangedAt  DateTime?

  deletedAt DateTime? @map("deleted_at")

  profile UserProfile?

  oauthAccounts OAuthAccount[]

  devices Device[]

  sessions Session[]

  @@index([status])
  @@index([verificationLevel])
  @@index([deletedAt])
  @@map("users")
}

model UserProfile {
  id String @id @default(uuid()) @db.Uuid

  userId String @unique @map("user_id") @db.Uuid

  firstName String @map("first_name") @db.VarChar(100)

  lastName String @map("last_name") @db.VarChar(100)

  displayName String @map("display_name") @db.VarChar(150)

  avatarUrl String? @map("avatar_url") @db.VarChar(500)

  createdAt DateTime @default(now()) @map("created_at")

  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([displayName])
  @@map("user_profiles")
}

model OAuthAccount {
  id String @id @default(uuid()) @db.Uuid

  userId String @map("user_id") @db.Uuid

  provider OAuthProvider

  providerUserId String @map("provider_user_id") @db.VarChar(255)

  providerEmail String @map("provider_email") @db.VarChar(320)

  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@index([userId])
  @@map("oauth_accounts")
}

model Device {
  id String @id @default(uuid()) @db.Uuid

  userId String @map("user_id") @db.Uuid

  deviceIdentifier String @map("device_identifier") @db.VarChar(255)

  deviceName String? @map("device_name") @db.VarChar(150)

  platform DevicePlatform

  browser String? @db.VarChar(100)

  operatingSystem String? @map("operating_system") @db.VarChar(100)

  lastSeenAt DateTime @map("last_seen_at")

  createdAt DateTime @default(now()) @map("created_at")

  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  sessions Session[]

  @@unique([userId, deviceIdentifier])
  @@index([userId])
  @@index([lastSeenAt])
  @@map("devices")
}

model Session {
  id String @id @default(uuid()) @db.Uuid

  userId String @map("user_id") @db.Uuid

  deviceId String @map("device_id") @db.Uuid

  refreshTokenHash String @map("refresh_token_hash") @db.VarChar(255)

  status SessionStatus @default(ACTIVE)

  expiresAt DateTime @map("expires_at")

  lastActivityAt DateTime @map("last_activity_at")

  revokedAt DateTime? @map("revoked_at")

  createdAt DateTime @default(now()) @map("created_at")

  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  device Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([deviceId])
  @@index([status])
  @@index([expiresAt])
  @@map("sessions")
}
